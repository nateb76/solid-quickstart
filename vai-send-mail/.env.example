# vAI Send Mail — Environment Variables
# Copy this to .env and fill in your keys. Never commit the real .env.

# PostGrid Print & Mail API Keys
# Test key renders letters and returns preview PDFs without mailing or charging.
# Live key actually sends physical mail.
POSTGRID_TEST_KEY=
POSTGRID_LIVE_KEY=

# Anthropic API Key (for AI validation checks)
ANTHROPIC_API_KEY=
